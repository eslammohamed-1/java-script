  "sections": [
    {
      "level": 0,
      "title": "الربط بالمفاهيم السابقة وأهداف التعلم",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "قبل ما تبدأ، لازم تكون فاهم:"
            },
            {
              "type": "unordered_list",
              "items": [
                "Arrays: تعريف array والوصول للعناصر بالـ index وتعديلها.",
                "Data Types: خصوصًا String و Number و Boolean.",
                "Functions: استدعاء function وتمرير arguments وفهم return value.",
                "if / else: اتخاذ قرارات بناءً على Boolean.",
                "Strict Equality و Type Coercion: لفهم البحث والمقارنات.",
                "console.log(): طباعة القيم في Console."
              ]
            }
          ]
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "بعد ما تخلص الدرس هتقدر:"
            },
            {
              "type": "ordered_list",
              "items": [
                "تفهم أن Array Methods هي functions مرتبطة بالـ array.",
                "تستخدم push لإضافة عنصر في آخر array.",
                "تستخدم unshift لإضافة عنصر في أول array.",
                "تستخدم pop لحذف آخر عنصر.",
                "تستخدم shift لحذف أول عنصر.",
                "تعرف return value لكل method.",
                "تستخدم indexOf لمعرفة مكان عنصر.",
                "تستخدم includes لفحص وجود عنصر.",
                "تدمج includes مع if لاتخاذ قرارات.",
                "تفهم mutation والبدائل non-mutating."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "مقدمة",
      "blocks": [
        {
          "type": "text",
          "text": "بعد ما عرفنا إزاي ننشئ Arrays ونوصل لعناصرها، محتاجين نعرف العمليات الأساسية اليومية: إضافة، حذف، وبحث. JavaScript توفر methods جاهزة لهذه العمليات."
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "الـ method هي function مرتبطة بقيمة/كائن معين، ونستدعيها باستخدام النقطة مثل arr.push(\"x\")."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "إيه هي Array Methods؟",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "Array Methods هي functions مدمجة نستدعيها مباشرة على arrays باستخدام dot notation. بعضها يغيّر الـ array الأصلي mutating، وبعضها يقرأ فقط ولا يغيّر الأصل."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "arrayName.methodName(arguments);"
        },
        {
          "type": "table",
          "environment": "tabular",
          "rows": [
            [
              "الجزء",
              "المعنى"
            ],
            [
              "arrayName",
              "اسم الـ array"
            ],
            [
              ".",
              "النقطة للوصول للـ method"
            ],
            [
              "methodName",
              "اسم العملية مثل push أو pop"
            ],
            [
              "arguments",
              "قيم تمرر للـ method إن كانت تحتاج"
            ]
          ]
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "كل method قد يكون له return value مختلف؛ لا تفترض أن كل methods ترجع array نفسها."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "Methods الإضافة: push و unshift",
      "blocks": []
    },
    {
      "level": 2,
      "title": "push: إضافة في الآخر",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "تضيف عنصرًا أو أكثر في نهاية array.",
                "تعمل mutation للـ array الأصلي.",
                "ترجع الطول الجديد بعد الإضافة."
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven', 'Peter'];\n\nconst newLength = friends.push('Jay');\nconsole.log(friends);\nconsole.log(newLength);"
        },
        {
          "type": "output",
          "text": "[\"Michael\", \"Steven\", \"Peter\", \"Jay\"]\n4"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "في أغلب الحالات تستخدم push بدون حفظ return value."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "unshift: إضافة في الأول",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "تضيف عنصرًا أو أكثر في بداية array.",
                "تعمل mutation للـ array الأصلي.",
                "ترجع الطول الجديد بعد الإضافة."
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven', 'Peter'];\n\nconst newLength = friends.unshift('John');\nconsole.log(friends);\nconsole.log(newLength);"
        },
        {
          "type": "output",
          "text": "[\"John\", \"Michael\", \"Steven\", \"Peter\"]\n4"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "على arrays كبيرة، unshift قد يكون أبطأ من push لأنه يحتاج إعادة ترتيب indexes للعناصر الموجودة."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "إضافة أكثر من عنصر",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const arr = ['A'];\n\nconsole.log(arr.push('B', 'C'));\nconsole.log(arr);\n\nconsole.log(arr.unshift('X', 'Y'));\nconsole.log(arr);"
        },
        {
          "type": "output",
          "text": "3\n[\"A\", \"B\", \"C\"]\n5\n[\"X\", \"Y\", \"A\", \"B\", \"C\"]"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "push و unshift يقبلان أكثر من argument."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "Methods الحذف: pop و shift",
      "blocks": []
    },
    {
      "level": 2,
      "title": "pop: حذف آخر عنصر",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "تحذف آخر عنصر من array.",
                "لا تحتاج arguments.",
                "تعمل mutation.",
                "ترجع العنصر الذي تم حذفه."
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven', 'Peter', 'Jay'];\n\nconst popped = friends.pop();\nconsole.log(popped);\nconsole.log(friends);"
        },
        {
          "type": "output",
          "text": "Jay\n[\"Michael\", \"Steven\", \"Peter\"]"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "pop ترجع العنصر المحذوف، وليس الطول الجديد."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "shift: حذف أول عنصر",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "تحذف أول عنصر من array.",
                "لا تحتاج arguments.",
                "تعمل mutation.",
                "ترجع العنصر الذي تم حذفه."
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['John', 'Michael', 'Steven'];\n\nconst removed = friends.shift();\nconsole.log(removed);\nconsole.log(friends);"
        },
        {
          "type": "output",
          "text": "John\n[\"Michael\", \"Steven\"]"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "على arrays كبيرة، shift قد يكون أبطأ من pop لأنه يحرك العناصر ويعيد ترتيب indexes."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "ماذا يحدث مع Array فارغة؟",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const arr = [];\n\nconsole.log(arr.pop());\nconsole.log(arr.shift());\nconsole.log(arr);"
        },
        {
          "type": "output",
          "text": "undefined\nundefined\n[]"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "pop و shift على array فارغة يرجعان undefined ولا يرميان Error."
            }
          ]
        }
      ]
    },
