    {
      "level": 1,
      "title": "Methods البحث: indexOf و includes",
      "blocks": []
    },
    {
      "level": 2,
      "title": "indexOf: مكان العنصر",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "ترجع index أول ظهور للعنصر.",
                "لو العنصر غير موجود ترجع -1.",
                "لا تغيّر الـ array الأصلي."
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven'];\n\nconsole.log(friends.indexOf('Steven'));\nconsole.log(friends.indexOf('Bob'));"
        },
        {
          "type": "output",
          "text": "1\n-1"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "استخدم indexOf عندما تحتاج رقم المكان، وليس فقط معرفة هل العنصر موجود."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "includes: هل العنصر موجود؟",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "ترجع true لو العنصر موجود.",
                "ترجع false لو غير موجود.",
                "لا تغيّر الـ array الأصلي.",
                "مناسبة جدًا مع if."
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven'];\n\nconsole.log(friends.includes('Steven'));\nconsole.log(friends.includes('Bob'));"
        },
        {
          "type": "output",
          "text": "true\nfalse"
        }
      ]
    },
    {
      "level": 2,
      "title": "دقة المقارنة: includes و indexOf",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const values = ['23', 23, NaN];\n\nconsole.log(values.includes('23'));\nconsole.log(values.includes(23));\nconsole.log(values.indexOf(NaN));\nconsole.log(values.includes(NaN));"
        },
        {
          "type": "output",
          "text": "true\ntrue\n-1\ntrue"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "تصحيح علمي مهم: includes لا تستخدم Strict Equality حرفيًا، بل تستخدم SameValueZero. عمليًا لا تعمل type coercion، لذلك \"23\" ليست 23، لكنها تستطيع إيجاد NaN. أما indexOf يعتمد على مقارنة شبيهة بـ === ولذلك لا يجد NaN لأن NaN لا يساوي نفسه."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "indexOf vs includes",
      "blocks": [
        {
          "type": "table",
          "environment": "longtable",
          "rows": [
            [
              "المقارنة",
              "indexOf",
              "includes"
            ],
            [
              "يرجع",
              "number: index أو -1",
              "boolean: true/false"
            ],
            [
              "أفضل عندما",
              "تحتاج مكان العنصر",
              "تحتاج فحص الوجود فقط"
            ],
            [
              "NaN",
              "لا يجده",
              "يجده"
            ],
            [
              "يغيّر الأصل؟",
              "لا",
              "لا"
            ]
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const arr = ['A', 'B', 'C'];\n\nconsole.log(arr.indexOf('B'));\nconsole.log(arr.includes('B'));\nconsole.log(arr.indexOf('Z'));\nconsole.log(arr.includes('Z'));"
        },
        {
          "type": "output",
          "text": "1\ntrue\n-1\nfalse"
        }
      ]
    },
    {
      "level": 1,
      "title": "استخدام includes مع if",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven', 'Peter'];\n\nif (friends.includes('Steven')) {\n  console.log('You have a friend called Steven');\n}"
        },
        {
          "type": "output",
          "text": "You have a friend called Steven"
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven', 'Peter'];\n\nif (friends.includes('Bob')) {\n  console.log('You have a friend called Bob');\n} else {\n  console.log('Bob is not in your friends list');\n}"
        },
        {
          "type": "output",
          "text": "Bob is not in your friends list"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "includes ترجع Boolean، لذلك تدخل مباشرة في شروط if."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "Mutation والبدائل غير المعدّلة Non-Mutating",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "push/pop/shift/unshift كلها تغيّر الـ array الأصلي. أحيانًا تريد إنشاء array جديدة بدل تعديل الأصل، خصوصًا في React أو عند تجنب side effects."
            }
          ]
        },
        {
          "type": "table",
          "environment": "longtable",
          "rows": [
            [
              "العملية",
              "Mutating",
              "Non-Mutating Alternative"
            ],
            [
              "إضافة في الآخر",
              "arr.push(el)",
              "const updated = [...arr, el]"
            ],
            [
              "إضافة في الأول",
              "arr.unshift(el)",
              "const updated = [el, ...arr]"
            ],
            [
              "حذف من الآخر",
              "arr.pop()",
              "const updated = arr.slice(0, -1)"
            ],
            [
              "حذف من الأول",
              "arr.shift()",
              "const updated = arr.slice(1)"
            ]
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const items = ['A', 'B'];\nconst updated = [...items, 'C'];\n\nconsole.log(items);\nconsole.log(updated);"
        },
        {
          "type": "output",
          "text": "[\"A\", \"B\"]\n[\"A\", \"B\", \"C\"]"
        }
      ]
    },
    {
      "level": 1,
      "title": "تتبع تنفيذ الكود خطوة بخطوة",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = ['Michael', 'Steven', 'Peter'];\n\nfriends.push('Jay');\nfriends.unshift('John');\nfriends.pop();\nfriends.pop();\nfriends.shift();\n\nconsole.log(friends.indexOf('Steven'));\nconsole.log(friends.includes('Steven'));\nconsole.log(friends.includes('Bob'));"
        },
        {
          "type": "box",
          "style": "step",
          "blocks": [
            {
              "type": "ordered_list",
              "items": [
                "البداية: [Michael, Steven, Peter].",
                "push(\"Jay\") تضيف Jay في الآخر: [Michael, Steven, Peter, Jay].",
                "unshift(\"John\") تضيف John في الأول: [John, Michael, Steven, Peter, Jay].",
                "pop() تحذف Jay.",
                "pop() تحذف Peter.",
                "shift() تحذف John، فيتبقى [Michael, Steven].",
                "indexOf(\"Steven\") يرجع 1.",
                "includes(\"Steven\") يرجع true.",
                "includes(\"Bob\") يرجع false."
              ]
            }
          ]
        },
        {
          "type": "output",
