    {
      "level": 1,
      "title": "الوصول لعناصر Array",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = [\"Michael\", \"Steven\", \"Peter\"];\n\nconsole.log(friends[0]);\nconsole.log(friends[2]);\nconsole.log(friends[3]);"
        },
        {
          "type": "output",
          "text": "Michael\nPeter\nundefined"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "Arrays تبدأ من index 0، وليس 1. ولو استخدمت index خارج الحدود سترجع undefined وليس Error."
            }
          ]
        },
        {
          "type": "table",
          "environment": "tabular",
          "rows": [
            [
              "العنصر",
              "Index"
            ],
