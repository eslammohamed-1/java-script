              "1"
            ],
            [
              "الثالث",
              "2"
            ]
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "خاصية length وآخر عنصر",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = [\"Michael\", \"Steven\", \"Peter\"];\n\nconsole.log(friends.length);\nconsole.log(friends[friends.length - 1]);\nconsole.log(friends.at(-1));"
        },
        {
          "type": "output",
          "text": "3\nPeter\nPeter"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "length هو عدد العناصر وليس آخر index.",
                "لو length = 3، آخر index هو 2.",
                "arr.at(-1) طريقة حديثة لجلب آخر عنصر."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "Expressions داخل []",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "داخل brackets للوصول للعنصر يمكن وضع أي expression ينتج index."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = [\"Michael\", \"Steven\", \"Peter\"];\nconst i = 1;\n\nconsole.log(friends[i]);\nconsole.log(friends[1 + 1]);\nconsole.log(friends[friends.length - 1]);"
        },
        {
          "type": "output",
          "text": "Steven\nPeter\nPeter"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "لا تضع statement داخل []؛ المطلوب قيمة أو expression ينتج قيمة."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "تعديل عناصر Array Mutation",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = [\"Michael\", \"Steven\", \"Peter\"];\n\nfriends[2] = \"Jay\";\nconsole.log(friends);"
        },
        {
          "type": "output",
          "text": "[\"Michael\", \"Steven\", \"Jay\"]"
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "ordered_list",
              "items": [
                "كانت القيمة في index 2 هي Peter.",
                "غيرناها إلى Jay.",
                "نفس array اتغيرت من الداخل. هذا يسمى mutation."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "const مع Arrays",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = [\"Michael\", \"Steven\", \"Peter\"];\n\nfriends[2] = \"Jay\";      // يعمل\n// friends = [\"Bob\"];    // TypeError: Assignment to constant variable"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "const يمنع إعادة تعيين المتغير نفسه لقيمة/array جديدة.",
                "const لا يمنع تعديل محتوى object أو array.",
                "السبب أن المتغير يحتفظ بمرجع reference للـ array، والمحتوى يمكن تغييره."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "Arrays هي Objects خاصة",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const friends = [\"Michael\", \"Steven\"];\n\nconsole.log(typeof friends);\nconsole.log(Array.isArray(friends));\nconsole.log(Array.isArray({}));"
        },
        {
          "type": "output",
          "text": "object\ntrue\nfalse"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "typeof array يرجع object. لفحص هل القيمة Array فعلاً استخدم Array.isArray(value)."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "أنواع بيانات مختلفة في Array واحد",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const firstName = \"Jonas\";\nconst friends = [\"Michael\", \"Steven\", \"Peter\"];\n\nconst jonas = [\n  firstName,\n  \"Schmedtmann\",\n  2037 - 1991,\n  \"teacher\",\n  friends\n];\n\nconsole.log(jonas);\nconsole.log(jonas.length);"
        },
        {
          "type": "output",
          "text": "[\"Jonas\", \"Schmedtmann\", 46, \"teacher\", [\"Michael\", \"Steven\", \"Peter\"]]\n5"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "أي موضع داخل array يقبل expression: literal value، variable، عملية حسابية، function call، array أخرى، object، إلخ."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "Functions مع Arrays",
      "blocks": []
    },
    {
      "level": 2,
      "title": "الدالة والبيانات",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const calcAge = function (birthYear) {\n  return 2037 - birthYear;\n};\n\nconst years = [1990, 1967, 2002, 2010, 2018];"
        }
      ]
    },
    {
      "level": 2,
      "title": "ما لا يعمل كما تتوقع",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(calcAge(years));\nconsole.log(years + 10);\nconsole.log(years - 10);"
        },
        {
          "type": "output",
          "text": "NaN\n1990,1967,2002,2010,201810\nNaN"
        },
        {
          "type": "box",
          "style": "error",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "calcAge يتوقع رقمًا، لكننا مررنا array كاملة.",
                "+ مع array يحولها غالبًا إلى string ثم يعمل concatenation.",
                "- يحاول تحويل array إلى number، وغالبًا يفشل فيعطي NaN."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "الطريقة الصحيحة",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const age1 = calcAge(years[0]);\nconst age2 = calcAge(years[1]);\nconst age3 = calcAge(years[years.length - 1]);\n\nconsole.log(age1, age2, age3);\n\nconst ages = [\n  calcAge(years[0]),\n  calcAge(years[1]),\n  calcAge(years[years.length - 1])\n];\nconsole.log(ages);"
        },
        {
          "type": "output",
          "text": "47 70 19\n[47, 70, 19]"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "استدعاء function هو expression ينتج قيمة، لذلك يمكن وضعه داخل array literal."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "Reference vs Copy",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "Arrays تُخزن وتُمرر بالمرجع reference. لو عملت const b = a، فهما يشيران لنفس array."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const a = [1, 2];\nconst b = a;\n\nb.push(3);\nconsole.log(a);\nconsole.log(b);"
        },
        {
          "type": "output",
          "text": "[1, 2, 3]\n[1, 2, 3]"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "لو تريد نسخة سطحية shallow copy استخدم spread أو slice."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const original = [1, 2];\nconst copy1 = [...original];\nconst copy2 = original.slice();\n\ncopy1.push(3);\nconsole.log(original);\nconsole.log(copy1);"
        },
        {
          "type": "output",
          "text": "[1, 2]\n[1, 2, 3]"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "spread و slice يعملان shallow copy فقط. لو داخل array objects أو arrays متداخلة، العناصر الداخلية ما زالت references."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "التحقق من Array فارغة",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const arr = [];\n\nconsole.log(Boolean(arr));\nconsole.log(arr.length > 0);\nconsole.log(Array.isArray(arr) && arr.length > 0);"
        },
        {
          "type": "output",
          "text": "true\nfalse\nfalse"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "[] قيمة truthy. لذلك if (arr) لا يعني أن المصفوفة فيها عناصر. استخدم arr.length أو Array.isArray(arr) && arr.length > 0."
            }
          ]
        }
      ]
    },
