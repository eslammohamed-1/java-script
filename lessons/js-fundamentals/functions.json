    {
      "level": 1,
      "title": "تتبع تنفيذ الكود خطوة بخطوة",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "function fruitProcessor(apples, oranges) {\n  const juice = `Juice with ${apples} apples and ${oranges} oranges.`;\n  return juice;\n}\n\nconst appleJuice = fruitProcessor(5, 0);\nconsole.log(appleJuice);"
        },
        {
          "type": "box",
          "style": "step",
          "blocks": [
            {
              "type": "ordered_list",
              "items": [
                "JavaScript تقرأ تعريف الدالة وتحفظه، ولا تنفذ body الآن.",
                "عند fruitProcessor(5, 0) يبدأ تشغيل الدالة.",
                "apples = 5 و oranges = 0.",
                "يتم بناء juice باستخدام template literal.",
                "return juice ترجع النص وتنهي الدالة.",
                "استدعاء الدالة يُستبدل بالقيمة الراجعة.",
                "appleJuice يحفظ القيمة ثم console.log يطبعها."
              ]
            }
          ]
        },
        {
          "type": "output",
          "text": "Juice with 5 apples and 0 oranges."
        }
