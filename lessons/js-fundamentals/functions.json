    {
      "level": 2,
      "title": "return يوقف تنفيذ الدالة",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "function example() {\n  console.log(\"Step 1\");\n  console.log(\"Step 2\");\n  return \"Done\";\n  console.log(\"Step 3\"); // unreachable\n}\n\nconst result = example();\nconsole.log(result);"
        },
        {
          "type": "output",
          "text": "Step 1\nStep 2\nDone"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "أي كود بعد return في نفس مسار التنفيذ لن يعمل. هذا يسمى Unreachable Code."
            }
          ]
        }
      ]
    },
