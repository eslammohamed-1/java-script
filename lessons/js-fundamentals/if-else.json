        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "الحل:"
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "const income = 200000;\nlet tax;\n\nif (income <= 50000) {\n  tax = 0;\n} else if (income <= 150000) {\n  tax = (income - 50000) * 0.10;\n} else if (income <= 300000) {\n  tax = (100000 * 0.10) + ((income - 150000) * 0.20);\n} else {\n  tax = (100000 * 0.10) + (150000 * 0.20) + ((income - 300000) * 0.30);\n}\n\nconst netIncome = income - tax;\n\nconsole.log(`Gross income: ${income} EGP`);\nconsole.log(`Tax: ${tax} EGP`);\nconsole.log(`Net income: ${netIncome} EGP`);"
            },
            {
              "type": "output",
              "text": "Gross income: 200000 EGP\nTax: 20000 EGP\nNet income: 180000 EGP"
            }
          ]
        }
      ]
    },
