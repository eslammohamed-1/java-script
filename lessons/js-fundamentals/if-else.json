  "sections": [
    {
      "level": 0,
      "title": "قبل البداية وأهداف التعلم",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "قبل ما تبدأ، لازم تكون فاهم:"
            },
            {
              "type": "unordered_list",
              "items": [
                "Values and Variables: تعريف المتغيرات بـ let و const.",
                "Data Types: خصوصًا Boolean و undefined و null.",
                "Comparison Operators: مثل > و < و >= و <=.",
                "Template Literals: بناء رسائل ديناميكية.",
                "console.log(): طباعة النتائج."
              ]
            }
          ]
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "بعد الدرس هتقدر:"
            },
            {
              "type": "ordered_list",
              "items": [
                "تفهم Control Structure و Control Flow.",
                "تكتب if statement بشرط واضح.",
                "تستخدم else للحالة البديلة.",
                "تستخدم else if للشروط المتعددة.",
                "تفهم أن الشرط يتم تقييمه إلى Boolean أو تحويله ضمنيًا.",
                "تتعامل مع block scope.",
                "تتجنب أخطاء مثل if (x = 5) و if (condition);.",
                "تبني قرارات عملية مثل فحص العمر والدرجات والضرائب."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "مقدمة",
      "blocks": [
        {
          "type": "text",
          "text": "البرامج الحقيقية لا تنفذ دائمًا كل سطر بنفس الترتيب. أحيانًا نحتاج قرارًا: لو الشرط صحيح نفذ كودًا، ولو غير صحيح نفذ بديلًا. هنا يأتي دور if / else."
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "تشبيه السينما: لو العمر 18 أو أكثر يدخل المستخدم، وإلا لا يدخل. هذا قرار مبني على شرط."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "إيه هو الـ Control Structure؟",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "Control Structure هي بنية تتحكم في مسار تنفيذ الكود. بدل التنفيذ الخطي فقط، نستطيع تنفيذ جزء وتخطي جزء بناءً على شرط."
            }
          ]
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "لو الشرط true: يدخل مسار if.",
                "لو الشرط false: يدخل مسار else إن وجد.",
                "بعد انتهاء أحد المسارين، يكمل البرنامج الكود التالي."
              ]
            }
          ]
        },
        {
          "type": "box",
          "style": "compare",
          "blocks": [
            {
              "type": "text",
              "text": "Linear Execution"
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "console.log('Step 1');\nconsole.log('Step 2');\nconsole.log('Step 3');"
            },
            {
              "type": "output",
              "text": "Step 1\nStep 2\nStep 3"
            }
          ]
        },
        {
          "type": "box",
          "style": "compare",
          "blocks": [
            {
              "type": "text",
              "text": "Conditional Execution"
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "const age = 20;\n\nif (age >= 18) {\n  console.log('You are an adult');\n} else {\n  console.log('You are a minor');\n}"
            },
            {
              "type": "output",
              "text": "You are an adult"
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "جملة if البسيطة",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "الصيغة العامة:"
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "if (condition) {\n  // runs if condition is true\n}"
            },
            {
              "type": "unordered_list",
              "items": [
                "condition هو expression يتم تقييمه إلى true أو false.",
                "الـ code block بين { } ينفذ فقط لو الشرط true.",
                "لو الشرط false، يتم تخطي البلوك."
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const age = 19;\n\nif (age >= 18) {\n  console.log('Sarah can start driving license');\n}"
        },
        {
          "type": "output",
          "text": "Sarah can start driving license"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "لو الشرط false، البلوك لا ينفذ، لكن الكود بعده يكمل طبيعيًا."
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "const age = 15;\n\nif (age >= 18) {\n  console.log('Sarah can start driving license');\n}\n\nconsole.log('This line always runs');"
            },
            {
              "type": "output",
              "text": "This line always runs"
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "إضافة else -- الحالة البديلة",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "الصيغة العامة:"
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "if (condition) {\n  // runs if true\n} else {\n  // runs if false\n}"
            },
            {
              "type": "text",
              "text": "واحد فقط من البلوكين ينفذ: إما if أو else."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const age = 15;\n\nif (age >= 18) {\n  console.log('Sarah can start driving license');\n} else {\n  const yearsLeft = 18 - age;\n  console.log(`Sarah is too young. Wait another ${yearsLeft} years`);\n}"
        },
        {
          "type": "output",
          "text": "Sarah is too young. Wait another 3 years"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "else اختياري. لو لا تريد فعل شيء عند false، يمكن كتابة if فقط."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "else if -- شروط متعددة",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "else if تستخدم عندما يكون عندك أكثر من احتمال، وليس فقط true/false بسيط."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const score = 75;\nlet grade;\n\nif (score >= 90) {\n  grade = 'Excellent';\n} else if (score >= 80) {\n  grade = 'Very Good';\n} else if (score >= 70) {\n  grade = 'Good';\n} else if (score >= 60) {\n  grade = 'Pass';\n} else {\n  grade = 'Fail';\n}\n\nconsole.log(`Score: ${score} - Grade: ${grade}`);"
        },
        {
          "type": "output",
          "text": "Score: 75 - Grade: Good"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "ترتيب else if مهم جدًا. ابدأ بالشروط الأكثر تحديدًا أو الأعلى أولًا في سلاسل الدرجات."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "الشرط Condition -- ماذا يوضع داخل if؟",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "أي expression يمكن وضعه داخل if. لو ليس Boolean صريحًا، JavaScript يحوله إلى Boolean ضمنيًا."
            }
          ]
        },
        {
          "type": "table",
          "environment": "tabular",
          "rows": [
            [
              "نوع الشرط",
              "مثال",
              "ملاحظات"
            ],
            [
              "مقارنة",
              "age >= 18",
              "ترجع Boolean"
            ],
            [
              "Boolean variable",
              "isLoggedIn",
              "واضح ومباشر"
            ],
            [
              "typeof",
              "typeof x === \"number\"",
              "مفيد لفحص النوع"
            ],
            [
              "Truthy/Falsy",
              "if (userName)",
              "يعتمد على التحويل الضمني"
            ]
          ]
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "القيم falsy الأساسية: false, 0, \"\", null, undefined, NaN. باقي القيم غالبًا truthy. سيتم شرح هذا بالتفصيل في درس Truthy and Falsy."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "if ('hello') console.log('runs');\nif (0) console.log('will not run');\nif ('') console.log('will not run');"
        },
        {
          "type": "output",
          "text": "runs"
        }
      ]
    },
    {
      "level": 1,
      "title": "Code Block و Block Scope",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "Code Block هو أي كود بين { }. متغيرات let و const المعرفة داخل البلوك لا تكون متاحة خارجه."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "if (true) {\n  const message = 'Hello from inside!';\n  console.log(message);\n}\n\n// console.log(message); // ReferenceError"
        },
        {
          "type": "output",
          "text": "Hello from inside!"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "لو تحتاج استخدام متغير بعد if / else، عرّفه خارج البلوك ثم غيّر قيمته داخله."
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "let message;\n\nif (true) {\n  message = 'Hello from inside!';\n} else {\n  message = 'Hello from else!';\n}\n\nconsole.log(message);"
            },
            {
              "type": "output",
              "text": "Hello from inside!"
            }
          ]
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "تنبيه متقدم: var لا يملك block scope مثل let/const، لذلك يفضّل استخدام let/const لتجنب الالتباس."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "مثال عملي: تحديد القرن من سنة الميلاد",
      "blocks": [
