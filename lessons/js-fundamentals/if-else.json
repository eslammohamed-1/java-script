          "type": "code",
          "language": "JavaScript",
          "code": "const temperature = 38;\n\nif (temperature > 35) {\n  console.log('Very hot! Stay hydrated');\n  console.log('Wear light clothes');\n} else {\n  console.log('Nice weather!');\n  console.log('Enjoy your day');\n}"
