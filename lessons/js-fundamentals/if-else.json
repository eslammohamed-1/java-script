              "type": "code",
              "language": "JavaScript",
              "code": "const age = 8;\nlet ticketPrice;\nlet ticketType;\n\nif (age < 5) {\n  ticketPrice = 0;\n  ticketType = 'Free';\n} else if (age <= 12) {\n  ticketPrice = 30;\n  ticketType = 'Child';\n} else if (age <= 64) {\n  ticketPrice = 60;\n  ticketType = 'Regular';\n} else {\n  ticketPrice = 35;\n  ticketType = 'Senior';\n}\n\nconsole.log(`Age: ${age} - Type: ${ticketType} - Ticket: ${ticketPrice} EGP`);"
            },
