            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "الفرق بين false و Falsy",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "false قيمة Boolean صريحة. أما falsy فهو وصف لأي قيمة تتحول إلى false عند الحاجة إلى Boolean."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(false === 0);\nconsole.log(Boolean(0));\nconsole.log(Boolean(''));\nconsole.log(Boolean(undefined));"
        },
        {
          "type": "output",
          "text": "false\nfalse\nfalse\nfalse"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "0 ليس false. لكنه يتحول إلى false في سياق منطقي. الفرق مهم جدًا عند المقارنات الصارمة ===."
            }
          ]
        }
      ]
    },
