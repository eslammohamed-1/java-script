        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(0 || 10);\nconsole.log(0 ?? 10);\nconsole.log('' || 'default');\nconsole.log('' ?? 'default');\nconsole.log(null ?? 'default');\nconsole.log(undefined ?? 'default');"
