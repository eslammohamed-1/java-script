              "code": "let height = 0;\n\nif (height !== undefined && height !== null) {\n  console.log('Height is defined');\n}\n\nif (typeof height === 'number' && !Number.isNaN(height)) {\n  console.log('Height is a valid number');\n}\n\nconst finalHeight = height ?? 180; // يحافظ على 0 ولا يستبدله"
            }
