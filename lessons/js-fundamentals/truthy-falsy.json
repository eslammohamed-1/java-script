    {
      "level": 1,
      "title": "Logical Operators وعلاقتها بـ Truthy/Falsy",
      "blocks": [
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "معلومة مهمة: || و && لا يرجعان true/false دائمًا. هما يرجعان إحدى القيم نفسها بناءً على truthy/falsy."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(0 || 'default');\nconsole.log('Ahmed' || 'default');\nconsole.log(0 && 'hello');\nconsole.log('Ahmed' && 'hello');\nconsole.log(!0);\nconsole.log(!'Ahmed');"
        },
        {
          "type": "output",
          "text": "default\nAhmed\n0\nhello\ntrue\nfalse"
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "|| يرجع أول قيمة truthy، أو آخر قيمة لو كلهم falsy.",
                "&& يرجع أول قيمة falsy، أو آخر قيمة لو كلهم truthy.",
                "! يحول إلى Boolean ثم يعكسها."
              ]
            }
          ]
        }
      ]
    },
