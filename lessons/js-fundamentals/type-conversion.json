            {
              "type": "ordered_list",
              "items": [
                "تفرّق بين Type Conversion و Type Coercion.",
                "تستخدم Number() لتحويل النصوص لأرقام.",
                "تستخدم String() لتحويل القيم لنصوص.",
                "تفهم Boolean() وعلاقته بـ truthy/falsy.",
                "تفهم NaN ومتى يظهر ولماذا typeof NaN هو number.",
                "تتوقع سلوك + و - و * و / مع أنواع مختلطة.",
                "تتعامل مع input.value وبيانات API بأمان.",
                "تختار بين || و ?? للقيم الافتراضية."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "مقدمة: ليه التحويل بين الأنواع مهم؟",
      "blocks": [
        {
          "type": "text",
          "text": "في JavaScript كثير من البيانات تأتي كنصوص حتى لو شكلها أرقام، خصوصًا من input fields و APIs. لذلك نحتاج تحويل الأنواع قبل الحساب أو المقارنة."
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "Type Conversion: تحويل يدوي وصريح مثل Number(\"23\").",
                "Type Coercion: تحويل تلقائي وضمني يحدث بسبب operators أو contexts مثل if."
              ]
            }
          ]
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "JavaScript قد تعطي نتائج تبدو غريبة لو لم تفهم قواعد coercion، مثل \"5\" + 3 التي تنتج \"53\" وليس 8."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "التحويل اليدوي Type Conversion",
      "blocks": []
    },
    {
      "level": 2,
      "title": "تحويل نص لرقم باستخدام Number()",
      "blocks": [
        {
          "type": "text",
          "text": "Number() تحول قيمة إلى رقم. لو القيمة نص رقمي مثل \"1991\" فترجع الرقم 1991."
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const inputYear = \"1991\";\n\nconsole.log(inputYear + 18);\nconsole.log(Number(inputYear) + 18);"
        },
        {
          "type": "output",
          "text": "199118\n2009"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "Number() لا تغير المتغير الأصلي، بل ترجع قيمة جديدة محولة."
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "const inputYear = \"1991\";\nconsole.log(Number(inputYear)); // 1991 number\nconsole.log(inputYear);         // \"1991\" string"
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "عندما يفشل التحويل: NaN",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(Number(\"Jonas\"));\nconsole.log(typeof NaN);"
        },
        {
          "type": "output",
          "text": "NaN\nnumber"
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "NaN اختصار Not a Number، لكنه من نوع number.",
                "المعنى الأدق: رقم غير صالح Invalid Number.",
                "أي عملية حسابية مع NaN غالبًا تنتج NaN."
              ]
            }
          ]
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "استخدم Number.isNaN() للفحص الآمن بعد التحويل."
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "const value = Number('hello');\nconsole.log(Number.isNaN(value)); // true"
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "تحويل رقم لنص باستخدام String()",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(String(23));\nconsole.log(typeof String(23));\nconsole.log(typeof 23);"
        },
        {
          "type": "output",
          "text": "23\nstring\nnumber"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "JavaScript حساسة لحالة الحروف: Number() و String() بحرف كبير، أما number() و string() فليست دوال built-in صحيحة."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "Boolean() والتحويل إلى Boolean",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "Boolean() تحول أي قيمة إلى true أو false حسب قواعد truthy/falsy."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(Boolean(0));\nconsole.log(Boolean(''));\nconsole.log(Boolean('hello'));\nconsole.log(Boolean(42));\nconsole.log(Boolean(null));\nconsole.log(Boolean(undefined));\nconsole.log(Boolean(NaN));"
        },
        {
          "type": "output",
          "text": "false\nfalse\ntrue\ntrue\nfalse\nfalse\nfalse"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "القيم falsy الأساسية: false, 0, \"\", null, undefined, NaN. وما عدا ذلك غالبًا truthy."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "Number() مقابل parseInt() و parseFloat()",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "Number() يحاول تحويل النص كله إلى رقم. parseInt و parseFloat يقرؤون الرقم من بداية النص فقط وقد يتوقفون عند أول جزء غير رقمي."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(Number('123px'));\nconsole.log(parseInt('123px', 10));\nconsole.log(parseFloat('12.5rem'));\nconsole.log(Number('12.5rem'));"
        },
        {
          "type": "output",
          "text": "NaN\n123\n12.5\nNaN"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "استخدم Number() عندما تتوقع أن النص كله رقم. استخدم parseInt/parseFloat عندما تتعامل مع نص يبدأ برقم مثل CSS values."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "التحويل التلقائي Type Coercion",
      "blocks": []
    },
    {
      "level": 2,
      "title": "المعامل + مع النصوص",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(\"I am \" + 23 + \" years old\");"
        },
        {
          "type": "output",
          "text": "I am 23 years old"
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "ordered_list",
              "items": [
                "+ وجد string.",
                "حوّل الرقم 23 إلى string.",
                "عمل concatenation."
              ]
            }
          ]
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "Template Literals تحول القيم إلى نصوص داخل ${} تلقائيًا عند بناء النص."
            },
            {
              "type": "code",
              "language": "JavaScript",
              "code": "console.log(`I am ${23} years old`);"
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "المعامل - مع النصوص",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(\"23\" - \"10\" - 3);"
        },
        {
          "type": "output",
          "text": "10"
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "- لا يعمل concatenation، لذلك يحاول تحويل النصوص الرقمية إلى numbers ثم يطرح."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "المعاملات * و /",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(\"23\" * \"2\");\nconsole.log(\"30\" / \"5\");"
        },
        {
          "type": "output",
          "text": "46\n6"
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "أي operator حسابي ما عدا + غالبًا يحاول تحويل النصوص إلى أرقام."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "ليه + مختلف عن الباقي؟",
      "blocks": [
        {
          "type": "table",
          "environment": "longtable",
          "rows": [
            [
              "التعبير",
              "الناتج",
              "السبب"
            ],
            [
              "\"10\" + 3",
              "\"103\"",
              "+ وجد string فعمل concatenation"
            ],
            [
              "\"10\" - 3",
              "7",
              "- حوّل string إلى number"
            ],
            [
              "\"10\" * 3",
              "30",
              "* حوّل string إلى number"
            ],
            [
              "\"10\" / 3",
              "3.333...",
              "/ حوّل string إلى number"
            ]
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(\"10\" + 3);\nconsole.log(\"10\" - 3);\nconsole.log(\"10\" * 3);\nconsole.log(\"10\" / 3);"
        },
        {
          "type": "output",
          "text": "103\n7\n30\n3.3333333333333335"
        }
      ]
    },
    {
      "level": 2,
      "title": "Unary Plus +value",
      "blocks": [
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "الـ unary plus هو + قبل قيمة واحدة، ويستخدم كاختصار لتحويل القيمة إلى Number."
            }
          ]
        },
        {
          "type": "code",
          "language": "JavaScript",
          "code": "const input = '42';\nconsole.log(+input);\nconsole.log(typeof +input);"
        },
        {
          "type": "output",
          "text": "42\nnumber"
        },
        {
          "type": "box",
          "style": "warning",
          "blocks": [
            {
              "type": "text",
              "text": "رغم أنه مختصر، Number(input) أوضح للمبتدئين وأفضل في الشروحات التعليمية."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "لعبة Guess the Output",
      "blocks": []
    },
    {
      "level": 2,
      "title": "المثال الأول",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "let n = \"1\" + 1;\nn = n - 1;\nconsole.log(n);"
        },
        {
          "type": "box",
          "style": "step",
          "blocks": [
            {
              "type": "text",
              "text": "الحل خطوة بخطوة:"
            },
            {
              "type": "ordered_list",
              "items": [
                "\"1\" + 1 ينتج \"11\" بسبب concatenation.",
                "\"11\" - 1 يحول \"11\" إلى 11 ثم يطرح."
              ]
            }
          ]
        },
        {
          "type": "output",
          "text": "10"
        }
      ]
    },
    {
      "level": 2,
      "title": "المثال الثاني",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(2 + 3 + 4 + \"5\");"
        },
        {
          "type": "box",
          "style": "step",
          "blocks": [
            {
              "type": "text",
              "text": "الحل خطوة بخطوة:"
            },
            {
              "type": "ordered_list",
              "items": [
                "2 + 3 = 5.",
                "5 + 4 = 9.",
                "9 + \"5\" ينتج \"95\"."
              ]
            }
          ]
        },
        {
          "type": "output",
          "text": "95"
        }
      ]
    },
    {
      "level": 2,
      "title": "المثال الثالث",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(\"10\" - \"4\" - \"3\" - 2 + \"5\");"
        },
        {
          "type": "box",
          "style": "step",
          "blocks": [
            {
              "type": "text",
              "text": "الحل خطوة بخطوة:"
            },
            {
              "type": "ordered_list",
              "items": [
                "\"10\" - \"4\" = 6.",
                "6 - \"3\" = 3.",
                "3 - 2 = 1.",
                "1 + \"5\" = \"15\"."
              ]
            }
          ]
        },
        {
          "type": "output",
          "text": "15"
        }
      ]
    },
    {
      "level": 2,
      "title": "مثال إضافي",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(5 + 3 + \"2\" - 1);"
        },
        {
          "type": "box",
          "style": "step",
          "blocks": [
            {
              "type": "text",
              "text": "الحل خطوة بخطوة:"
            },
            {
              "type": "ordered_list",
              "items": [
                "5 + 3 = 8.",
                "8 + \"2\" = \"82\".",
                "\"82\" - 1 = 81."
              ]
            }
          ]
        },
        {
          "type": "output",
          "text": "81"
        }
      ]
    },
