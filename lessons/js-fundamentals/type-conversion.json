    {
      "level": 1,
      "title": "أسئلة لاختبار فهمك",
      "blocks": [
        {
          "type": "ordered_list",
          "items": [
            {
              "question": "ما الفرق بين Type Conversion و Type Coercion؟",
              "answer": "Conversion صريح تكتبه أنت، Coercion ضمني تقوم به JavaScript."
            },
            {
              "question": "ما نتيجة \"5\" + 3 و \"5\" - 3؟",
              "answer": "الأولى \"53\" لأن + مع string يدمج، والثانية 2 لأن - يحول إلى number."
            },
            {
              "question": "ما نوع NaN؟",
              "answer": "typeof NaN هو number لأنه رقم غير صالح."
            },
            {
              "question": "ما نتيجة let result = \"10\" - \"5\" + \"3\"؟",
              "answer": "\"53\" لأن الطرح ينتج 5 ثم + مع \"3\" يدمج."
            },
            {
              "question": "لماذا Number(\"hello\") ترجع NaN؟",
              "answer": "لأن النص لا يمثل رقمًا صالحًا."
            },
            {
              "question": "لماذا NaN === NaN يرجع false؟",
              "answer": "NaN قيمة خاصة لا تساوي نفسها. افحصها بـ Number.isNaN."
            },
            {
              "question": "متى تستخدم ?? بدل ||؟",
              "answer": "عندما تريد fallback فقط مع null أو undefined وليس مع 0 أو \"\"."
            }
          ]
        }
      ]
    },
