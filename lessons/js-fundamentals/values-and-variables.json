              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "مقدمة",
      "blocks": [
        {
          "type": "text",
          "text": "القيم Values والمتغيرات Variables هم أساس كل حاجة في البرمجة. القيمة هي البيانات نفسها، والمتغير هو اسم نستخدمه للإشارة لقيمة أو نتيجة مخزنة/مرتبطة في البرنامج."
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "القيمة Value = قطعة بيانات مثل نص أو رقم أو Boolean.",
                "المتغير Variable = اسم/identifier نستخدمه للوصول لقيمة.",
                "التشبيه البسيط: المتغير صندوق عليه ليبل. علميًا أدق: المتغير binding بين اسم وقيمة في بيئة التنفيذ."
              ]
            }
          ]
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "تحسين علمي: في JavaScript، المتغير ليس دائمًا “الصندوق” نفسه بالمعنى الحرفي، لكنه اسم يتم ربطه بقيمة. التشبيه مفيد للمبتدئين، لكن في المستوى الأدق نقول إن الاسم identifier يشير إلى value أو reference حسب نوع القيمة."
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "إيه هي القيمة Value؟",
      "blocks": []
    },
    {
      "level": 2,
      "title": "التعريف",
      "blocks": [
        {
          "type": "text",
          "text": "القيمة Value هي أصغر وحدة بيانات يتعامل معها البرنامج. ممكن تكون String أو Number أو Boolean أو undefined أو null أو Object وغيرها."
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "text",
              "text": "معلومة مهمة: بعض القيم primitive مثل numbers وstrings وbooleans، وبعضها reference values مثل objects وarrays. التفاصيل هتيجي في درس Data Types."
            }
          ]
        }
      ]
    },
    {
      "level": 2,
      "title": "أمثلة على القيم",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(\"Jonas\");  // String value\nconsole.log(23);       // Number value\nconsole.log(true);     // Boolean value"
        },
        {
          "type": "output",
          "text": "Jonas\n23\ntrue"
        }
      ]
    },
    {
      "level": 2,
      "title": "القيم في العمليات الحسابية",
      "blocks": [
        {
          "type": "code",
          "language": "JavaScript",
          "code": "console.log(40 + 8 + 23 - 10);"
        },
        {
          "type": "output",
          "text": "61"
        },
        {
          "type": "box",
          "style": "info",
          "blocks": [
            {
              "type": "unordered_list",
              "items": [
                "لدينا 4 قيم رقمية: 40 و 8 و 23 و 10.",
                "العمليات + و - تنتج قيمة جديدة.",
                "الناتج النهائي 61 هو أيضًا قيمة."
              ]
            }
          ]
        }
      ]
    },
    {
      "level": 1,
      "title": "إيه هو المتغير Variable؟",
      "blocks": []
    },
    {
      "level": 2,
      "title": "التعريف",
      "blocks": [
        {
          "type": "text",
          "text": "المتغير هو اسم نعرّفه في البرنامج لكي نستخدمه لاحقًا للوصول لقيمة. في JavaScript الاسم يسمى identifier، وعملية ربط الاسم بالقيمة تتم داخل بيئة التنفيذ."
        },
        {
          "type": "box",
          "style": "tip",
          "blocks": [
            {
              "type": "text",
              "text": "تشبيه الصندوق ممتاز كبداية: القيمة هي الشيء داخل الصندوق، واسم المتغير هو الليبل. لكن تذكّر أن JavaScript فعليًا تتعامل مع bindings وقيم وreferences."
            }
          ]
        }
      ]
    },
